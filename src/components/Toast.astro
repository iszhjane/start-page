---
// 顶部居中悬浮提示
// 通过 window.dispatchEvent(new CustomEvent("toast", { detail: { msg, kind } })) 触发
// kind: "info" | "error"
---

<div id="toast-host" role="status" aria-live="assertive"></div>

<style is:global>
  #toast-host {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 500;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .toast {
    pointer-events: auto;
    background: var(--surface-translucent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 10px 16px;
    font-size: 13px;
    color: var(--text);
    max-width: 480px;
    text-align: center;
    animation: toast-in 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .toast.error {
    border-color: color-mix(in srgb, #c0392b 50%, var(--border));
    color: color-mix(in srgb, #c0392b 80%, var(--text));
  }

  .toast.info {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
  }

  .toast.leaving {
    animation: toast-out 200ms ease forwards;
  }

  @keyframes toast-in {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes toast-out {
    to {
      opacity: 0;
      transform: translateY(-12px);
    }
  }
</style>

<script>
  const host = document.getElementById("toast-host")!;

  window.addEventListener("toast", (e) => {
    const detail = (e as CustomEvent<{ msg: string; kind?: "info" | "error" }>).detail;
    if (!detail?.msg) return;
    show(detail.msg, detail.kind ?? "info");
  });

  function show(msg: string, kind: "info" | "error"): void {
    const el = document.createElement("div");
    el.className = `toast ${kind}`;
    el.textContent = msg;
    host.appendChild(el);

    setTimeout(() => {
      el.classList.add("leaving");
      setTimeout(() => el.remove(), 220);
    }, 2400);
  }
</script>

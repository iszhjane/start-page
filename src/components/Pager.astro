---
// 圆点分页指示器
// 仅当 totalPages > 1 时显示
// 监听 pager:update 事件更新页数；监听 pager:reset 重置到第 1 页
---

<div id="pager" class="pager" hidden></div>

<style>
  .pager {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 4px 0;
  }

  .pager-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition:
      background var(--transition),
      transform var(--transition),
      width var(--transition);
  }

  .pager-dot:hover {
    background: var(--muted);
    transform: scale(1.2);
  }

  .pager-dot.active {
    background: var(--accent);
    width: 24px;
    border-radius: 4px;
  }
</style>

<script>
  const pagerEl = document.getElementById("pager")!;
  let totalPages = 0;
  let currentPage = 0;

  window.addEventListener("pager:update", (e) => {
    const detail = (e as CustomEvent<{ totalPages: number }>).detail;
    totalPages = detail?.totalPages ?? 0;
    currentPage = 0;
    render();
  });

  window.addEventListener("pager:reset", () => {
    if (totalPages > 0) {
      currentPage = 0;
      render();
      scrollToPage(0);
    }
  });

  // 每次 DOM 重建后重新绑定 scroll 监听
  window.addEventListener("pager:bind", () => bindTrackScroll());
  // 首次渲染也绑定（如果 DOMContentLoaded 时 track 已存在）
  if (document.readyState !== "loading") {
    bindTrackScroll();
  } else {
    document.addEventListener("DOMContentLoaded", () => bindTrackScroll());
  }

  function onTrackScroll(this: HTMLElement): void {
    const pageWidth = this.clientWidth;
    if (pageWidth > 0) {
      const newPage = Math.round(this.scrollLeft / pageWidth);
      if (newPage !== currentPage) {
        currentPage = newPage;
        render();
      }
    }
  }

  function bindTrackScroll(): void {
    const oldTrack = document.querySelector<HTMLElement>(".bookmark-pages-track");
    if (oldTrack) {
      oldTrack.removeEventListener("scroll", onTrackScroll);
    }
    const track = document.querySelector<HTMLElement>(".bookmark-pages-track");
    if (track) {
      track.addEventListener("scroll", onTrackScroll);
    }
  }

  function scrollToPage(index: number): void {
    const track = document.querySelector<HTMLElement>(".bookmark-pages-track");
    if (track) {
      track.scrollTo({ left: index * track.clientWidth, behavior: "smooth" });
    }
  }

  function render(): void {
    if (totalPages <= 1) {
    pagerEl.setAttribute("hidden", "");
    pagerEl.innerHTML = "";
    return;
  }
  pagerEl.removeAttribute("hidden");
    pagerEl.innerHTML = Array.from({ length: totalPages })
      .map(
        (_, i) =>
          `<button type="button" class="pager-dot ${i === currentPage ? "active" : ""}" data-page="${i}" aria-label="第 ${i + 1} 页" ${i === currentPage ? 'aria-current="page"' : ""}></button>`,
      )
      .join("");
    pagerEl.querySelectorAll<HTMLButtonElement>(".pager-dot").forEach((btn) => {
      btn.addEventListener("click", () => {
        const page = Number(btn.dataset.page);
        currentPage = page;
        render();
        scrollToPage(page);
      });
    });
  }
</script>
